{
  "name": "@ldesign/auth-core",
  "version": "0.1.0",
  "description": "LDesign 认证系统核心模块 - 框架无关的认证管理、Token 管理、会话管理",
  "keywords": [
    "ldesign",
    "auth",
    "authentication",
    "jwt",
    "token",
    "session",
    "typescript",
    "framework-agnostic"
  ],
  "author": "LDesign Team",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.cjs",
      "default": "./es/index.js"
    },
    "./auth": {
      "types": "./es/auth/index.d.ts",
      "import": "./es/auth/index.js",
      "require": "./lib/auth/index.cjs",
      "default": "./es/auth/index.js"
    },
    "./auth/*": {
      "types": "./es/auth/*.d.ts",
      "import": "./es/auth/*.js",
      "require": "./lib/auth/*.cjs",
      "default": "./es/auth/*.js"
    },
    "./errors": {
      "types": "./es/errors/index.d.ts",
      "import": "./es/errors/index.js",
      "require": "./lib/errors/index.cjs",
      "default": "./es/errors/index.js"
    },
    "./errors/*": {
      "types": "./es/errors/*.d.ts",
      "import": "./es/errors/*.js",
      "require": "./lib/errors/*.cjs",
      "default": "./es/errors/*.js"
    },
    "./events": {
      "types": "./es/events/index.d.ts",
      "import": "./es/events/index.js",
      "require": "./lib/events/index.cjs",
      "default": "./es/events/index.js"
    },
    "./events/*": {
      "types": "./es/events/*.d.ts",
      "import": "./es/events/*.js",
      "require": "./lib/events/*.cjs",
      "default": "./es/events/*.js"
    },
    "./logger": {
      "types": "./es/logger/index.d.ts",
      "import": "./es/logger/index.js",
      "require": "./lib/logger/index.cjs",
      "default": "./es/logger/index.js"
    },
    "./logger/*": {
      "types": "./es/logger/*.d.ts",
      "import": "./es/logger/*.js",
      "require": "./lib/logger/*.cjs",
      "default": "./es/logger/*.js"
    },
    "./middleware": {
      "types": "./es/middleware/index.d.ts",
      "import": "./es/middleware/index.js",
      "require": "./lib/middleware/index.cjs",
      "default": "./es/middleware/index.js"
    },
    "./middleware/*": {
      "types": "./es/middleware/*.d.ts",
      "import": "./es/middleware/*.js",
      "require": "./lib/middleware/*.cjs",
      "default": "./es/middleware/*.js"
    },
    "./session": {
      "types": "./es/session/index.d.ts",
      "import": "./es/session/index.js",
      "require": "./lib/session/index.cjs",
      "default": "./es/session/index.js"
    },
    "./session/*": {
      "types": "./es/session/*.d.ts",
      "import": "./es/session/*.js",
      "require": "./lib/session/*.cjs",
      "default": "./es/session/*.js"
    },
    "./storage": {
      "types": "./es/storage/index.d.ts",
      "import": "./es/storage/index.js",
      "require": "./lib/storage/index.cjs",
      "default": "./es/storage/index.js"
    },
    "./storage/*": {
      "types": "./es/storage/*.d.ts",
      "import": "./es/storage/*.js",
      "require": "./lib/storage/*.cjs",
      "default": "./es/storage/*.js"
    },
    "./token": {
      "types": "./es/token/index.d.ts",
      "import": "./es/token/index.js",
      "require": "./lib/token/index.cjs",
      "default": "./es/token/index.js"
    },
    "./token/*": {
      "types": "./es/token/*.d.ts",
      "import": "./es/token/*.js",
      "require": "./lib/token/*.cjs",
      "default": "./es/token/*.js"
    },
    "./types": {
      "types": "./es/types/index.d.ts",
      "import": "./es/types/index.js",
      "require": "./lib/types/index.cjs",
      "default": "./es/types/index.js"
    },
    "./types/*": {
      "types": "./es/types/*.d.ts",
      "import": "./es/types/*.js",
      "require": "./lib/types/*.cjs",
      "default": "./es/types/*.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./lib/index.cjs",
  "module": "./es/index.js",
  "types": "./es/index.d.ts",
  "unpkg": "./dist/index.min.js",
  "jsdelivr": "./dist/index.min.js",
  "files": [
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "es",
    "lib",
    "dist"
  ],
  "scripts": {
    "build": "ldesign-builder build",
    "dev": "ldesign-builder build --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rimraf es lib dist coverage"
  },
  "dependencies": {},
  "peerDependencies": {},
  "devDependencies": {
    "@ldesign/builder": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "typings": "./es/index.d.ts",
  "browser": "./dist/index.js"
}